    </joint>

    <joint name="joint_6">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

<gazebo>
  <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
    <parameters>/home/maxence/ros2_ws/install/mon_robot_gazebo/share/mon_robot_gazebo/config/robot_controllers.yaml</parameters>
  </plugin>
</gazebo>

