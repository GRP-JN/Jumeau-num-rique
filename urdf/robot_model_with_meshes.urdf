<?xml version="1.0"?>
<robot name="staubli_tx60">

  <!-- 
    VERSION AVEC MESHES STL
    
    IMPORTANT : Dé-commenter les sections mesh et commenter les primitives géométriques
    pour utiliser les STL. Cette version est un template à adapter selon vos fichiers STL.
    
    Pour éviter les bugs :
    1. S'assurer que tous les fichiers STL existent dans meshes/
    2. Vérifier les chemins package://mon_projet_jumeau/meshes/...
    3. Valider avec : rosrun urdf_parser check_urdf robot_model.urdf
  -->

  <link name="world"/>
  
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <!-- Option 1 : Primitive (défaut, robuste) -->
        <cylinder radius="0.1" length="0.2"/>
        <!-- Option 2 : Mesh STL (décommenter si fichier existe)
        <mesh filename="package://mon_projet_jumeau/meshes/base_link.stl" scale="1 1 1"/>
        -->
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.2"/>
        <!-- <mesh filename="package://mon_projet_jumeau/meshes/base_link.stl"/> -->
      </geometry>
    </collision>
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <link name="link1">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.3"/>
        <!-- <mesh filename="package://mon_projet_jumeau/meshes/link1.stl" scale="1 1 1"/> -->
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.3"/>
        <!-- <mesh filename="package://mon_projet_jumeau/meshes/link1.stl"/> -->
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
    </inertial>
  </link>

  <link name="link2">
    <visual>
      <origin xyz="0.3 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.6 0.1 0.1"/>
        <!-- <mesh filename="package://mon_projet_jumeau/meshes/link2.stl" scale="1 1 1"/> -->
      </geometry>
      <material name="green">
        <color rgba="0.0 1.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.3 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.6 0.1 0.1"/>
        <!-- <mesh filename="package://mon_projet_jumeau/meshes/link2.stl"/> -->
      </geometry>
    </collision>
    <inertial>
      <mass value="4.0"/>
      <inertia ixx="0.04" ixy="0" ixz="0" iyy="0.04" iyz="0" izz="0.04"/>
    </inertial>
  </link>

  <link name="link3">
    <visual>
      <origin xyz="0.3 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.4"/>
        <!-- <mesh filename="package://mon_projet_jumeau/meshes/link3.stl" scale="1 1 1"/> -->
      </geometry>
      <material name="yellow">
        <color rgba="1.0 1.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0.3 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.06" length="0.4"/>
        <!-- <mesh filename="package://mon_projet_jumeau/meshes/link3.stl"/> -->
      </geometry>
    </collision>
    <inertial>
      <mass value="3.0"/>
      <inertia ixx="0.03" ixy="0" ixz="0" iyy="0.03" iyz="0" izz="0.03"/>
    </inertial>
  </link>

  <link name="link4">
    <visual>
      <origin xyz="0 0 0.2" rpy="0 0 0"/>
      <geometry>
        <box size="0.4 0.08 0.08"/>
        <!-- <mesh filename="package://mon_projet_jumeau/meshes/link4.stl" scale="1 1 1"/> -->
      </geometry>
      <material name="orange">
        <color rgba="1.0 0.5 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.2" rpy="0 0 0"/>
      <geometry>
        <box size="0.4 0.08 0.08"/>
        <!-- <mesh filename="package://mon_projet_jumeau/meshes/link4.stl"/> -->
      </geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>
  </link>

  <link name="link5">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.3"/>
        <!-- <mesh filename="package://mon_projet_jumeau/meshes/link5.stl" scale="1 1 1"/> -->
      </geometry>
      <material name="purple">
        <color rgba="0.5 0.0 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.3"/>
        <!-- <mesh filename="package://mon_projet_jumeau/meshes/link5.stl"/> -->
      </geometry>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.015" ixy="0" ixz="0" iyy="0.015" iyz="0" izz="0.015"/>
    </inertial>
  </link>

  <link name="link6">
    <visual>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.2"/>
        <!-- <mesh filename="package://mon_projet_jumeau/meshes/link6.stl" scale="1 1 1"/> -->
      </geometry>
      <material name="red">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.2"/>
        <!-- <mesh filename="package://mon_projet_jumeau/meshes/link6.stl"/> -->
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <link name="pyrometer_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.1"/>
        <!-- <mesh filename="package://mon_projet_jumeau/meshes/pyrometer.stl" scale="1 1 1"/> -->
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.1"/>
        <!-- <mesh filename="package://mon_projet_jumeau/meshes/pyrometer.stl"/> -->
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <link name="buse_link">
    <visual>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.15"/>
        <!-- <mesh filename="package://mon_projet_jumeau/meshes/buse.stl" scale="1 1 1"/> -->
      </geometry>
      <material name="silver">
        <color rgba="0.8 0.8 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.15"/>
        <!-- <mesh filename="package://mon_projet_jumeau/meshes/buse.stl"/> -->
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
  </link>

  <!-- Jointures du robot -->
  <joint name="base_to_world" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="100" velocity="1.0"/>
  </joint>

  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0.3" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.0944" upper="2.0944" effort="100" velocity="1.0"/>
  </joint>

  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0.6 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.618" upper="2.618" effort="100" velocity="1.0"/>
  </joint>

  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0 0 0.4" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="100" velocity="1.0"/>
  </joint>

  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0.4 0 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.0944" upper="2.0944" effort="100" velocity="1.0"/>
  </joint>

  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="0 0 0.3" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="100" velocity="1.0"/>
  </joint>

  <!-- Capteurs attachés à l'effecteur final -->
  <joint name="pyrometer_joint" type="fixed">
    <parent link="link6"/>
    <child link="pyrometer_link"/>
    <origin xyz="0.1 0 0.1" rpy="0 0 0"/>
  </joint>

  <joint name="buse_joint" type="fixed">
    <parent link="link6"/>
    <child link="buse_link"/>
    <origin xyz="-0.1 0 0.1" rpy="0 0 0"/>
  </joint>

</robot>