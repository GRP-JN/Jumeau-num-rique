<?xml version="1.0"?>
<robot name="robot_model">
  
  <!-- Liens du robot -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.5 0.5 0.1"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
  </link>
  
  <link name="pyrometer_link">
    <visual>
      <geometry>
        <cylinder radius="0.02" length="0.1"/>
      </geometry>
      <material name="red">
        <color rgba="1.0 0.0 0.0 1.0"/>
      </material>
    </visual>
  </link>
  
  <link name="buse_link">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.2"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
      </material>
    </visual>
  </link>
  
  <!-- Jointures -->
  <joint name="pyrometer_joint" type="fixed">
    <parent link="base_link"/>
    <child link="pyrometer_link"/>
    <origin xyz="0.2 0 0.05"/>
  </joint>
  
  <joint name="buse_joint" type="fixed">
    <parent link="base_link"/>
    <child link="buse_link"/>
    <origin xyz="-0.2 0 0.05"/>
  </joint>
  
</robot>